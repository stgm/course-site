<%= form_with(model: @alert, id: 'alert_form') do |f| %>

  <% if @alert.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@alert.errors.count, "error") %>
        prohibited this alert from being saved:</h2>

      <ul>
        <% @alert.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title %><br>
    <%= f.text_field :title, class: "form-control", autofocus: true, required: true %>
  </div>
  <div class="mb-3">
    <%= f.label :body %><br>
    <%= f.text_area :body, class: "form-control", rows: 10, required: true %>
  </div>
  <div class="form-check pb-1">
    <%= f.check_box :published, class: "form-check-input" %>
    <%= f.label :published, class: "form-check-label" %>
  </div>

  <% if AlertMailer.available? %>
    <div class="form-check pb-1">
      <%= checkbox_tag :send_mail,
      "1",
      false,
      onclick:
        "document.getElementById('send_mail_to_done').disabled = !this.checked;",
      class: "form-check-input" %>
      <%= label_tag :send_mail,
      t("helpers.label.alert.send_mail"),
      class: "form-check-label" %>
    </div>
    <div class="form-check pb-3">
      <%= checkbox_tag :send_mail_to_done, disabled: true, class: "form-check-input" %>
      <%= label_tag :send_mail_to_done,
      t("helpers.label.alert.send_mail_to_done"),
      class: "form-check-label" %>
    </div>
  <% else %>
    <div class="form-check ps-1 pb-3">
      <%= checkbox_tag :send_mail, "0", false, disabled: true, class: "form-check-input" %>
      <%= label_tag :send_mail,
      t("helpers.label.alert.send_mail_disabled"),
      class: "form-check-label" %>
    </div>
  <% end %>

  <div class="form-check pb-1">
    <input
      type="radio"
      name="alert[schedule_id]"
      <%= 'checked="checked"' if @alert.persisted? && @alert.schedule_id.nil? %>
      required
      id="alert_schedule_id_0"
      value="<%= nil %>"
      class="form-check-input"
    >
    <%# send to everyone %>
    <%= f.label :schedule_id_0, class: "form-check-label" %>
  </div>

  <%= f.collection_radio_buttons(:schedule_id, Schedule.all, :id, :name) do |b|
    content_tag(:div, class: "form-check pb-1") do
      b.radio_button(class: "form-check-input") +
        b.label(class: "form-check-label") { b.text }
    end
  end %>

<% end %>
